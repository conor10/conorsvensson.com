---
import { compile } from 'vega-lite';
import { parse, View } from 'vega';
import type { TopLevelSpec } from 'vega-lite';

interface Props {
  spec: TopLevelSpec | Record<string, any>;
}

const { spec } = Astro.props;

// Compile Vega-Lite -> Vega, then render the Vega runtime to an SVG string
// at build time. `renderer: 'none'` means we never touch a browser DOM;
// toSVG() produces the final markup itself.
const vgSpec = compile(spec as TopLevelSpec).spec;
const runtime = parse(vgSpec);
const view = new View(runtime, { renderer: 'none' });
const svg = await view.toSVG();
---
<figure class="vega-chart" set:html={svg}></figure>

<style>
  .vega-chart {
    margin: 1.75rem 0;
  }
  .vega-chart :global(svg) {
    max-width: 100%;
    height: auto;
    display: block;
  }
</style>
