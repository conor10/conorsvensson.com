---
import { compile } from 'vega-lite';
import { parse, View } from 'vega';

interface Props {
  spec: object;
}

const { spec } = Astro.props;

const vegaSpec = compile(spec as any).spec;
const runtime = parse(vegaSpec);
const view = new View(runtime, { renderer: 'none' });
let svg = await view.toSVG();

// Strip the explicit width/height attributes from the root <svg> so CSS
// (width: 100%, height: auto) governs rendered size. viewBox is left in
// place so the intrinsic aspect ratio is preserved and height scales.
svg = svg.replace(/<svg\b([^>]*)>/, (_match, attrs: string) => {
  const cleaned = attrs
    .replace(/\s+width="[^"]*"/g, '')
    .replace(/\s+height="[^"]*"/g, '');
  return `<svg${cleaned}>`;
});
---

<figure class="vega-chart" set:html={svg} />

<style>
  .vega-chart {
    margin: 2rem 0;
    width: 100%;
  }
  .vega-chart :global(svg) {
    width: 100%;
    height: auto;
    display: block;
  }
</style>