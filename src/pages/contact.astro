---
import BaseLayout from '../layouts/BaseLayout.astro';
import { FORMSPREE_ENDPOINT } from '../consts';
---
<BaseLayout
  title="Contact"
  description="Send Conor Svensson a message."
>
  <article class="prose">
    <h1>Contact</h1>
    <p>
      For most things, dropping a note here is the fastest way to reach me.
      I read everything and usually reply within a few days.
    </p>

    <form id="contact-form" class="contact-form" action={FORMSPREE_ENDPOINT} method="POST">
      <label>
        <span>Name</span>
        <input type="text" name="name" autocomplete="name" required />
      </label>
      <label>
        <span>Email</span>
        <input type="email" name="email" autocomplete="email" required />
      </label>
      <label>
        <span>Message</span>
        <textarea name="message" rows="5" required></textarea>
      </label>

      <!-- Honeypot for spam bots; Formspree ignores submissions with this filled. -->
      <input type="text" name="_gotcha" class="honeypot" tabindex="-1" autocomplete="off" aria-hidden="true" />
      <input type="hidden" name="_subject" value="Contact via conorsvensson.com" />

      <button type="submit">Send message</button>
    </form>

    <div id="contact-success" class="contact-status success" hidden>
      Thanks — I'll reply when I can.
    </div>
    <div id="contact-error" class="contact-status error" hidden>
      Something went wrong sending that. Please try again in a moment.
    </div>

    <p style="margin-top: 3rem; color: var(--fg-muted); font-size: 0.9rem;">
      Also on <a href="https://x.com/ConorSvensson">X</a> and
      <a href="https://www.linkedin.com/in/conorsvensson">LinkedIn</a>.
    </p>
  </article>
</BaseLayout>

<style>
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 2rem 0 1.5rem;
  }
  .contact-form label {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.9rem;
    color: var(--fg-muted);
  }
  .contact-form input[type="text"],
  .contact-form input[type="email"],
  .contact-form textarea {
    font: inherit;
    font-size: 1rem;
    color: var(--fg);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.6rem 0.75rem;
    width: 100%;
  }
  .contact-form textarea {
    resize: vertical;
    min-height: 8rem;
    line-height: 1.55;
  }
  .contact-form input:focus,
  .contact-form textarea:focus {
    outline: none;
    border-color: var(--fg-muted);
  }
  .contact-form button {
    align-self: flex-start;
    font: inherit;
    padding: 0.55rem 1.2rem;
    background: var(--fg);
    color: var(--bg);
    border: 0;
    border-radius: var(--radius);
    cursor: pointer;
  }
  .contact-form button:hover { opacity: 0.88; }
  .contact-form button:disabled { opacity: 0.6; cursor: progress; }

  .honeypot {
    position: absolute !important;
    left: -9999px !important;
    width: 1px; height: 1px;
    opacity: 0;
  }

  .contact-status {
    padding: 0.85rem 1rem;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    margin: 1rem 0;
    font-size: 0.95rem;
  }
  .contact-status.success { border-color: var(--accent); color: var(--fg); }
  .contact-status.error   { color: var(--fg); }
</style>

<script is:inline>
  (function () {
    const form = document.getElementById('contact-form');
    const ok = document.getElementById('contact-success');
    const err = document.getElementById('contact-error');
    if (!form || !ok || !err) return;

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const btn = form.querySelector('button[type="submit"]');
      btn.disabled = true;
      ok.hidden = true;
      err.hidden = true;

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { 'Accept': 'application/json' },
        });
        if (res.ok) {
          form.hidden = true;
          ok.hidden = false;
          ok.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else {
          err.hidden = false;
          btn.disabled = false;
        }
      } catch (_) {
        err.hidden = false;
        btn.disabled = false;
      }
    });
  })();
</script>
