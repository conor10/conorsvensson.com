---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Buttondown from '../components/Buttondown.astro';

const posts = (await getCollection('writing', ({ data }) => !import.meta.env.PROD || !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---
<BaseLayout>
  <section class="intro">
    <p>
      I'm Conor Svensson — a technical founder in London. 
      I've spent a decade building developer tools and infrastructure for blockchains. 
      These days I write here about how AI is changing the way I build things.
    </p>
  </section>

  <div class="section-heading">Latest writing</div>
  <ul class="post-list">
    {posts.map((post) => (
      <li>
        <h3><a href={`/writing/${post.id}/`}>{post.data.title}</a></h3>
        <FormattedDate date={post.data.date} />
        {post.data.description && <p>{post.data.description}</p>}
      </li>
    ))}
  </ul>
  <p style="margin-top: 1rem;"><a href="/writing">All posts →</a></p>

  <Buttondown />
</BaseLayout>
