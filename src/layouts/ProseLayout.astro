---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
}

const { title, description, bodyClass } = Astro.props.frontmatter ?? Astro.props;
---
<BaseLayout title={title} description={description}>
  <article class:list={['prose', bodyClass]}>
    <slot />
  </article>
</BaseLayout>
